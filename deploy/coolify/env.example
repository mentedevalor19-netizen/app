# URLs publicas do app
SITE_URL=https://app.qgdaforra.online
BASE_URL=https://app.qgdaforra.online
APP_TIMEZONE=America/Sao_Paulo
APP_DEBUG=0

# Supabase / PostgreSQL
# Se preencher DB_DSN, ele tem prioridade sobre DB_HOST/PORT/NAME.
# Recomendacao para VPS IPv4: use o Session Pooler do Supabase na porta 5432.
DB_DRIVER=pgsql
DB_DSN=pgsql:host=aws-0-us-east-1.pooler.supabase.com;port=5432;dbname=postgres;sslmode=require
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.WLM1fHeZlCtIbhB3
DB_PASS=w9SxC0g1NAQA6OMwKUxTiTF6mW3K2iUH
DB_SCHEMA=public
DB_SSLMODE=require
DB_EMULATE_PREPARES=1

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABCDEF
TELEGRAM_GROUP_ID=-1001234567890
WEBHOOK_SECRET=troque-este-segredo

# PestoPay
PESTOPAY_PUBLIC_KEY=sua-public-key
PESTOPAY_SECRET_KEY=sua-secret-key

# Webhook global do n8n para eventos do app
# Pode ser publico ou interno na rede do compose, por exemplo:
# N8N_WEBHOOK_URL=http://n8n:5678/webhook/app-events
N8N_WEBHOOK_URL=https://n8n.qgdaforra.online/webhook/app-events
N8N_SECRET=segredo-compartilhado-com-o-n8n
N8N_TIMEOUT=15

# Produto padrao
DEFAULT_PRODUCT_NAME=Acesso VIP - 30 dias
DEFAULT_PRODUCT_DESCRIPTION=Acesso completo ao grupo por 30 dias
DEFAULT_PRODUCT_PRICE=29.90
DEFAULT_PRODUCT_DAYS=30

# Convite / fallback legado
ACCESS_LINK=
ACCESS_TOKEN_SALT=troque-o-salt

# SMTP opcional
EMAIL_FROM=no-reply@seudominio.com
EMAIL_FROM_NAME=Seu Projeto
EMAIL_SUBJECT=Pagamento Confirmado - Acesso Liberado!
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# Worker interno do compose
WORKER_LIMIT=25
WORKER_SLEEP=60

# n8n
N8N_IMAGE_TAG=stable
N8N_HOST=n8n.seudominio.com
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://n8n.qgdaforra.online
N8N_PUBLIC_WEBHOOK_URL=https://n8n.qgdaforra.online
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque-essa-senha
N8N_ENCRYPTION_KEY=uma-chave-longa-e-unica
N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=true
