# Workers a cada minuto
* * * * * cd /var/www/telegram-bot/current/deploy/vps && /usr/bin/docker compose exec -T app php /var/www/html/worker_runner.php all >> /var/log/telegram-bot-workers.log 2>&1

# Expiracao de acessos a cada 5 minutos
*/5 * * * * cd /var/www/telegram-bot/current/deploy/vps && /usr/bin/docker compose exec -T app php /var/www/html/cron_expiracao.php >> /var/log/telegram-bot-expiracao.log 2>&1
